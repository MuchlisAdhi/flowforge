# ===========================================
# FlowForge Environment Configuration
# ===========================================

# Application
APP_NAME=FlowForge
APP_ENV=local
APP_DEBUG=true

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=flowforge
DB_USERNAME=postgres
DB_PASSWORD=sidoagung

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=flowforge
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=/

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_TTL=60

# AI Service
AI_PROVIDER=mock
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Execution Engine
EXECUTION_MAX_PARALLEL=10
EXECUTION_GLOBAL_TIMEOUT=3600

# Frontend
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws
